{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ForgeWorkout Program File",
  "type": "object",
  "required": ["schemaVersion", "meta", "days"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Version of the ForgeWorkout program schema. Currently only 1 is supported."
    },
    "meta": {
      "type": "object",
      "required": ["name", "durationDays"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "durationDays": { "type": "integer", "minimum": 1 },
        "targetCalories": { "type": "number", "minimum": 0 },
        "targetProtein": { "type": "number", "minimum": 0 },
        "startDate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "yyyy-mm-dd. Defaults to the date the program is imported if omitted."
        },
        "notes": { "type": "string" }
      }
    },
    "days": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/day" }
    }
  },
  "definitions": {
    "day": {
      "type": "object",
      "required": ["day"],
      "additionalProperties": false,
      "properties": {
        "day": { "type": "integer", "minimum": 1, "description": "1-based day index within the program." },
        "isRestDay": { "type": "boolean" },
        "workout": {
          "oneOf": [{ "$ref": "#/definitions/workout" }, { "type": "null" }]
        },
        "diet": {
          "oneOf": [{ "$ref": "#/definitions/diet" }, { "type": "null" }]
        },
        "notes": { "type": "string" }
      }
    },
    "workout": {
      "type": "object",
      "required": ["title", "exercises"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" },
        "exercises": {
          "type": "array",
          "items": { "$ref": "#/definitions/exercise" }
        }
      }
    },
    "exercise": {
      "type": "object",
      "required": ["name", "sets", "reps"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "sets": { "type": "number", "exclusiveMinimum": 0 },
        "reps": { "type": "string", "minLength": 1, "description": "Free-form: \"12\", \"8-10\", \"30s\", \"AMRAP\"." },
        "weight": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "diet": {
      "type": "object",
      "required": ["meals"],
      "additionalProperties": false,
      "properties": {
        "meals": {
          "type": "array",
          "items": { "$ref": "#/definitions/meal" }
        },
        "notes": { "type": "string" }
      }
    },
    "meal": {
      "type": "object",
      "required": ["type", "items"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["breakfast", "lunch", "dinner", "snack", "custom"] },
        "label": { "type": "string", "description": "Shown when type is \"custom\"." },
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/foodItem" }
        }
      }
    },
    "foodItem": {
      "type": "object",
      "required": ["name", "calories", "protein", "carbs", "fat"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "quantity": { "type": "string" },
        "calories": { "type": "number", "minimum": 0 },
        "protein": { "type": "number", "minimum": 0 },
        "carbs": { "type": "number", "minimum": 0 },
        "fat": { "type": "number", "minimum": 0 }
      }
    }
  }
}
